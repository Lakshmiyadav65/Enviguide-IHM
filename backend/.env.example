# IHM EnviGuide Backend — Environment Variables
#
# Copy to `.env` (or `.env.local`) and tweak.
# Lines that are commented out (starting with `#`) are OPTIONAL — leave
# them off and the code will fall back to a local-only behaviour:
#
#   - File storage falls back to disk under ./uploads (served by the
#     express static handler at /uploads/...).
#   - Email falls back to a "log to stdout" transport. Audit / reminder
#     flows still work, mail just doesn't actually leave the machine.
#
# Set the optional blocks only when you want real cloud delivery.

# ─── Server ──────────────────────────────────────────────────────────
PORT=8000
NODE_ENV=development

# ─── Database (PostgreSQL) ───────────────────────────────────────────
# Local Postgres (recommended for laptop testing):
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ihm_enviguide
#
# Or hosted (Supabase pooler, Neon, RDS, etc.) — Linode prod will
# point here:
# DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# ─── Auth ────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_string
JWT_EXPIRES_IN=7d

# ─── CORS ────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ─── Local file uploads (used when no S3 vars are set below) ─────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# ─── Cloud file storage (OPTIONAL — leave unset for local-disk) ──────
# When ALL four S3_* vars below are set, uploads go to that bucket and
# we return public URLs. Otherwise files stay on local disk under
# UPLOAD_DIR and we serve them via the /uploads/* express handler.
# Works with Supabase Storage, Cloudflare R2, AWS S3, MinIO, etc.
# S3_ENDPOINT=https://<project>.supabase.co/storage/v1/s3
# S3_REGION=ap-south-1
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_BUCKET=enviguide-files
# S3_FORCE_PATH_STYLE=true
# S3_PUBLIC_BASE_URL=https://<project>.supabase.co/storage/v1/object/public/enviguide-files

# ─── Email (OPTIONAL — leave unset to log to stdout instead) ─────────
# Senders are tried in this priority order: Brevo > Resend > SMTP > log.
# For local testing leave them all unset; emails will be logged to the
# console and the rest of the flow (audit status flips, reminder
# counters) still runs.
# EMAIL_FROM="EnviGuide IHM <noreply@yourdomain.com>"
#
# Brevo (HTTPS, single-sender verified — easiest for prod):
# BREVO_API_KEY=
#
# Resend (HTTPS, requires verified domain):
# RESEND_API_KEY=
#
# Plain SMTP (local Mailtrap, your own server, etc.):
# SMTP_HOST=smtp.mailtrap.io
# SMTP_PORT=2525
# SMTP_USER=
# SMTP_PASS=
#
# Test escape hatch — when set, ALL outgoing mail is rerouted to this
# single inbox. Original recipients are preserved in the subject and
# a banner inside the body so the tester can still tell which vendor
# each mail was meant for.
# EMAIL_TEST_REDIRECT_TO=

# ─── Public URLs (used in clarification emails) ──────────────────────
# Where the supplier upload page lives — the link in clarification
# emails is built from this. For local testing point to your dev
# server.
PUBLIC_FRONTEND_URL=http://localhost:5173
