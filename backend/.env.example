# IHM EnviGuide Backend — Environment Variables
# Copy this file to .env for local development (never commit .env)

# Server
PORT=8000
NODE_ENV=development

# Database (PostgreSQL via Prisma)
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/ihm_enviguide

# JWT
JWT_SECRET=change_this_to_a_long_random_secret_string
JWT_EXPIRES_IN=7d

# CORS – allow requests from the frontend dev server
CORS_ORIGIN=http://localhost:5173

# File uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10
